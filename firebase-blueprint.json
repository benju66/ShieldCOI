{
  "entities": {
    "project": {
      "title": "Project",
      "description": "A construction/development project requiring COI tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "number": { "type": "string" },
        "target_completion_date": { "type": "string", "format": "date" },
        "requirements": {
          "type": "object",
          "properties": {
            "gl_occurrence": { "type": "number" },
            "gl_aggregate": { "type": "number" },
            "auto_limit": { "type": "number" },
            "workers_comp": { "type": "boolean" },
            "warn_days_out": { "type": "number" },
            "gl_products_completed": { "type": "number" },
            "umbrella_limit": { "type": "number" },
            "employers_liability_accident": { "type": "number" },
            "employers_liability_disease_person": { "type": "number" },
            "employers_liability_disease_limit": { "type": "number" }
          },
          "required": [
            "gl_occurrence",
            "gl_aggregate",
            "auto_limit",
            "workers_comp",
            "warn_days_out",
            "gl_products_completed",
            "umbrella_limit",
            "employers_liability_accident",
            "employers_liability_disease_person",
            "employers_liability_disease_limit"
          ]
        },
        "custom_requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
               "label": { "type": "string" },
              "limit": { "type": "number" }
            },
            "required": ["id", "label", "limit"]
          }
        },
        "email_templates": {
          "type": "object",
          "properties": {
            "expired_template": { "type": "string" },
            "insufficient_template": { "type": "string" }
          },
          "required": ["expired_template", "insufficient_template"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "number", "target_completion_date", "requirements", "createdAt"]
    },
    "subcontractor": {
      "title": "Subcontractor",
      "description": "A subcontractor hired for a specific project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "project_id": { "type": "string" },
        "company_name": { "type": "string" },
        "trade": { "type": "string" },
        "contract_value": { "type": "number" },
        "compliance_status": { "type": "string", "enum": ["Compliant", "Insufficient Coverage", "Expired", "Pending Upload", "Approved Exception"] },
        "manual_override": { "type": "boolean" },
        "override_notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "vendor_type": { "type": "string", "enum": ["Subcontractor", "Supplier"] },
        "waiver_reason_type": { "type": ["string", "null"], "enum": ["Low Contract Value", "Low-Risk Scope", "Executive Discretion", "Temporary Extension", null] },
        "waiver_authorized_by": { "type": ["string", "null"] },
        "waiver_expiration_date": { "type": ["string", "null"], "format": "date" }
      },
      "required": ["id", "project_id", "company_name", "trade", "contract_value", "compliance_status", "manual_override", "createdAt", "vendor_type"]
    },
    "coi_record": {
      "title": "CoiRecord",
      "description": "An uploaded COI record for a subcontractor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subcontractor_id": { "type": "string" },
        "project_id": { "type": "string" },
        "uploaded_at": { "type": "string", "format": "date-time" },
        "file_name": { "type": "string" },
        "insured_extracted_name": { "type": "string" },
        "gl_occurrence_extracted": { "type": "number" },
        "gl_aggregate_extracted": { "type": "number" },
        "auto_combined_single_limit_extracted": { "type": "number" },
        "workers_comp_statutory_extracted": { "type": "boolean" },
        "policy_expiration_date_extracted": { "type": "string", "format": "date" },
        "gl_products_completed_extracted": { "type": "number" },
        "umbrella_limit_extracted": { "type": "number" },
        "employers_liability_accident_extracted": { "type": "number" },
        "employers_liability_disease_person_extracted": { "type": "number" },
        "employers_liability_disease_limit_extracted": { "type": "number" },
        "professional_liability_extracted": { "type": "number" },
        "pollution_liability_extracted": { "type": "number" },
        "validation_errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "extraction_method": {
          "type": "string",
          "enum": ["AI_Scan", "Manual_Entry"]
        },
        "custom_extractions": {
          "type": "object",
          "additionalProperties": {
            "type": ["number", "null"]
          }
        }
      },
      "required": ["id", "subcontractor_id", "project_id", "uploaded_at", "file_name", "validation_errors"]
    },
    "notification": {
      "title": "Notification",
      "description": "A compliance notification or alert.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "project_id": { "type": "string" },
        "project_name": { "type": "string" },
        "subcontractor_name": { "type": "string" },
        "type": { "type": "string", "enum": ["danger", "warning", "info"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "resolved": { "type": "boolean" }
      },
      "required": ["id", "project_id", "project_name", "subcontractor_name", "type", "message", "timestamp", "resolved"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "project",
      "description": "Construction projects collection"
    },
    "/projects/{projectId}/subcontractors/{subcontractorId}": {
      "schema": "subcontractor",
      "description": "Subcontractors assigned to a project"
    },
    "/projects/{projectId}/subcontractors/{subcontractorId}/cois/{coiId}": {
      "schema": "coi_record",
      "description": "COI files uploaded and scanned for a subcontractor"
    },
    "/notifications/{notificationId}": {
      "schema": "notification",
      "description": "System-wide notification log"
    }
  }
}
