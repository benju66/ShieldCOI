# GEMINI_API_KEY: Required for real Gemini AI document scanning.
# If unset, the app still works but returns simulated/mock extractions.
# Locally: copy this file to ".env" and fill in your key.
# On Vercel: add this as an Environment Variable in Project Settings.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase (shared backend). Frontend vars are safe to expose — Row-Level
# Security protects the data. See docs/supabase-migration.md.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-publishable-key"
# Server-side only (edge functions / admin). Keep secret; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
