rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'number', 'target_completion_date', 'requirements', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.number is string && data.number.size() <= 100
        && data.target_completion_date is string
        && data.requirements is map
        && data.createdAt is string;
    }

    function isValidSubcontractor(data) {
      return data.keys().hasAll(['id', 'project_id', 'company_name', 'trade', 'contract_value', 'compliance_status', 'manual_override', 'createdAt', 'vendor_type'])
        && data.id is string && data.id.size() <= 128
        && data.project_id is string && data.project_id.size() <= 128
        && data.company_name is string && data.company_name.size() <= 250
        && data.trade is string && data.trade.size() <= 100
        && data.contract_value is number
        && data.compliance_status is string
        && data.manual_override is bool
        && data.createdAt is string
        && data.vendor_type is string;
    }

    function isValidCoiRecord(data) {
      return data.keys().hasAll(['id', 'subcontractor_id', 'project_id', 'uploaded_at', 'file_name', 'validation_errors'])
        && data.id is string && data.id.size() <= 128
        && data.subcontractor_id is string && data.subcontractor_id.size() <= 128
        && data.project_id is string && data.project_id.size() <= 128
        && data.uploaded_at is string
        && data.file_name is string && data.file_name.size() <= 300
        && data.validation_errors is list;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'project_id', 'project_name', 'subcontractor_name', 'type', 'message', 'timestamp', 'resolved'])
        && data.id is string && data.id.size() <= 128
        && data.project_id is string && data.project_id.size() <= 128
        && data.project_name is string && data.project_name.size() <= 200
        && data.subcontractor_name is string && data.subcontractor_name.size() <= 250
        && data.type is string
        && data.message is string && data.message.size() <= 500
        && data.timestamp is string
        && data.resolved is bool;
    }

    // --- Collections ---

    // Projects collection
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && isValidId(projectId) 
        && isValidProject(incoming());
      
      allow update: if isSignedIn() 
        && isValidId(projectId) 
        && isValidProject(incoming());
        
      allow delete: if isSignedIn() && isValidId(projectId);

      // Subcontractors subcollection
      match /subcontractors/{subcontractorId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && isValidId(subcontractorId)
          && isValidSubcontractor(incoming());
        
        allow update: if isSignedIn()
          && isValidId(subcontractorId)
          && isValidSubcontractor(incoming());
          
        allow delete: if isSignedIn() && isValidId(subcontractorId);

        // COIs subcollection
        match /cois/{coiId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn()
            && isValidId(coiId)
            && isValidCoiRecord(incoming());
          
          allow update: if isSignedIn()
            && isValidId(coiId)
            && isValidCoiRecord(incoming());
            
          allow delete: if isSignedIn() && isValidId(coiId);
        }
      }
    }

    // Notifications log collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && isValidId(notificationId)
        && isValidNotification(incoming());
      
      allow update: if isSignedIn()
        && isValidId(notificationId)
        && isValidNotification(incoming());
        
      allow delete: if isSignedIn() && isValidId(notificationId);
    }
  }
}
